# Copy the contents of this file into Streamlit Cloud → App Settings → Secrets
# Do NOT commit this file with real keys.

GEMINI_API_KEY = "paste-your-gemini-key-here"
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_FALLBACK_MODELS = "gemini-2.5-flash,gemini-1.5-flash"

MARKETAUX_API_TOKEN = "paste-your-marketaux-token-here"

FRED_API_KEY = "paste-your-fred-key-here"

# Optional: manual yield overrides (leave blank or remove if not needed)
# MANUAL_BUND_10Y = "2.45"
# MANUAL_CH_10Y = "0.55"

# Optional: override event marker dates
